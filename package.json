{
  "name": "autoplan",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "node --test tests/*.test.js",
    "copy": "shx cp ./node_modules/@agilebot/extension-runtime/dist/browser.js ./static/extension-runtime.js",
    "build:frontend": "babel static/i18n.js --out-file=static/i18n-compiled.js && babel static/api-i18n-keys.js --out-file=static/api-i18n-keys-compiled.js && babel static/language-switcher.js --out-file=static/language-switcher-compiled.js && babel static/script.js --out-file=static/script-compiled.js",
    "build": "nr copy && nr build:frontend",
    "watch": "nr build --watch"
  },
  "dependencies": {
    "@agilebot/extension-runtime": "1.0.0-beta.13"
  },
  "devDependencies": {
    "@antfu/ni": "^24.3.0",
    "@babel/cli": "^7.27.0",
    "@babel/core": "^7.26.10",
    "@babel/preset-env": "^7.26.9",
    "only-allow": "^1.2.1",
    "shx": "^0.4.0"
  },
  "babel": {
    "presets": [
      [
        "@babel/preset-env",
        {
          "modules": false,
          "targets": {
            "ie": "11"
          }
        }
      ]
    ]
  }
}
